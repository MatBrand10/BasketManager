{
  "name": "basket-manager",
  "version": "0.2.0",
  "description": "Basket Manager - desktop build",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "cross-env CHANNEL=local electron-builder --dir",
    "pack:win": "cross-env CHANNEL=local electron-builder --dir --win --x64",
    "pack:linux": "cross-env CHANNEL=local electron-builder --dir --linux",
    "pack:mac": "cross-env CHANNEL=local electron-builder --dir --mac",
    "dist": "cross-env CHANNEL=stable electron-builder",
    "dist:win": "cross-env CHANNEL=stable electron-builder --win --x64",
    "dist:win:beta": "cross-env CHANNEL=beta electron-builder --win --x64",
    "dist:win:dev": "cross-env CHANNEL=dev electron-builder --win --x64",
    "dist:linux": "cross-env CHANNEL=stable electron-builder --linux",
    "dist:mac": "cross-env CHANNEL=stable electron-builder --mac",
    "dist:all": "cross-env CHANNEL=stable electron-builder -mwl",
    "icon:icns": "python scripts/generate-icns.py",
    "build": "electron-builder"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.basketmanager.app",
    "productName": "Basket Manager",
    "executableName": "BasketManager",
    "artifactName": "${productName}-${version}-${env.CHANNEL}.${ext}",
    "icon": "assets/icon.png",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!steam/**",
      "!node_modules/.cache/**"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "artifactName": "BasketManager-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/icon.icns",
      "artifactName": "${productName}-${version}-${env.CHANNEL}-mac.${ext}",
      "target": "dmg"
    },
    "linux": {
      "icon": "assets/icon.png",
      "artifactName": "${productName}-${version}-${env.CHANNEL}-linux.${ext}",
      "target": "AppImage"
    }
  }
}
